APP_NAME="IMS Logistics"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://ims-logistics.test

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — PostgreSQL via Laragon
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ims_logistics
DB_USERNAME=postgres
DB_PASSWORD=

# Queue — use 'database' locally if Redis not available, 'redis' in production
QUEUE_CONNECTION=database
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=480

# Storage — S3 for signatures, photos, visa documents (ap-southeast-2 = Australia)
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-2
AWS_BUCKET=ims-logistics
AWS_USE_PATH_STYLE_ENDPOINT=false

# Firebase — Push notifications
FIREBASE_PROJECT_ID=
FIREBASE_SERVER_KEY=
FIREBASE_CREDENTIALS_PATH=

# Twilio — SMS notifications
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Google Cloud Vision — OCR for paper worksheets
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# Sanctum — API mobile authentication
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,ims-logistics.test

# Mail (optional)
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@ims.com.au"
MAIL_FROM_NAME="${APP_NAME}"
